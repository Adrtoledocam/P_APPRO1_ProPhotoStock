<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProPhotoStock.Pages.ContratctsPage"
             BackgroundColor="White"
             Title="Contrats">

    <CollectionView x:Name="ContractsList" ItemsLayout="VerticalList" SelectionMode="None" Margin="20" BackgroundColor="White">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border Background="White" StrokeThickness="0" StrokeShape="RoundRectangle 20" Padding="15" Margin="0,10">
                    <VerticalStackLayout Spacing="10">
                        <HorizontalStackLayout >
                            <Label Text="Contrat # " FontAttributes="Bold" FontSize="16" TextColor="Black" />
                            <Label Text="{Binding contractId}" FontSize="16" FontAttributes="Bold" TextColor="Black" />
                            <Label Text=" - " />
                            <Label Text="{Binding status}" TextTransform="Uppercase" FontSize="12" VerticalOptions="Center" TextColor="Black" />
                        </HorizontalStackLayout>

                        <Label Text="{Binding photoTitle}" FontSize="14" TextColor="Black" />
                        <Image Source="{Binding photoUrl}" HeightRequest="150" Aspect="AspectFill" />
                       
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="Valable jusqu'au :" TextColor="Black" />
                            <Label Text="{Binding DisplayDate}" TextColor="Black" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="Type : "  TextColor="Black"   />
                            <Label Text="{Binding TypeName}"  TextColor="Black"  />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="Usage : "  TextColor="Black"  />
                            <Label Text="{Binding UsageName}"  TextColor="Black"  />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="Coût :" FontAttributes="Bold" TextColor="Black" />
                            <Label Text="{Binding price}" FontSize="16" TextColor="#0F5F68" FontAttributes="Bold" />
                        </HorizontalStackLayout>
                        
                    </VerticalStackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>


</ContentPage>